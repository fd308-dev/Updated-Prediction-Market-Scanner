# Anthropic API key (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Kalshi credentials (one of these two options required)
# Option A: Email + password (will auto-login on each scan)
KALSHI_EMAIL=your@email.com
KALSHI_PASSWORD=yourpassword

# Option B: Pre-fetched session token (faster, skip login round-trip)
# Get by logging into Kalshi and copying the token from your browser's
# network requests, or from a previous login response.
# KALSHI_API_TOKEN=

# Polymarket — no credentials needed (uses public Gamma API)
